HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# Frontend content proxy
# URL publica o interna del Strapi que contiene los contenidos del portal.
# En local normalmente queda asi:
STRAPI_URL=http://localhost:1337
# Token de API de Strapi con permisos de lectura para noticias, servicios,
# categorias de noticias, tramites, cortes programados, medios de pago, alertas y preguntas frecuentes.
# No se expone al navegador: se usa solo en el proxy backend /api/frontend/*.
STRAPI_TOKEN=

# Importador WordPress
# Ruta opcional del XML exportado desde WordPress. Si se omite, usa data/wordpress/export.xml.
WP_XML_PATH=data/wordpress/export.xml

# Compatibilidad con nombres anteriores. Se pueden eliminar cuando el hosting
# ya tenga configuradas STRAPI_URL y STRAPI_TOKEN.
STRAPI_API_URL=http://localhost:1337
STRAPI_API_TOKEN=
