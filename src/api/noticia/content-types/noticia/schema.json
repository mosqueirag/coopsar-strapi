{
  "kind": "collectionType",
  "collectionName": "noticias",
  "info": {
    "singularName": "noticia",
    "pluralName": "noticias",
    "displayName": "Noticia",
    "description": "Noticias y comunicados institucionales"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "titulo": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "titulo",
      "required": true
    },
    "resumen": {
      "type": "text"
    },
    "contenido": {
      "type": "richtext",
      "required": true
    },
    "imagen_destacada": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "servicio": {
      "type": "enumeration",
      "enum": [
        "Energia",
        "Telecomunicaciones",
        "Sepelio",
        "Institucional",
        "ADECOOP"
      ]
    },
    "fecha_publicacion": {
      "type": "datetime"
    }
  }
}