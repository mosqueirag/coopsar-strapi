{
  "kind": "collectionType",
  "collectionName": "noticias",
  "info": {
    "singularName": "noticia",
    "pluralName": "noticias",
    "displayName": "Noticia",
    "description": "Noticias y comunicados institucionales"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "titulo": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "titulo",
      "required": true
    },
    "resumen": {
      "type": "text"
    },
    "contenido": {
      "type": "richtext",
      "required": true
    },
    "imagen_destacada": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "categorias": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::categoria-noticia.categoria-noticia",
      "inversedBy": "noticias"
    },
    "servicio": {
      "type": "enumeration",
      "enum": [
        "Energia",
        "Telecomunicaciones",
        "Sepelio",
        "Institucional",
        "ADECOOP"
      ]
    },
    "fecha_publicacion": {
      "type": "datetime"
    },
    "autor": {
      "type": "string"
    },
    "wp_id_original": {
      "type": "integer",
      "unique": true
    },
    "wp_url_original": {
      "type": "string"
    },
    "wp_imagen_original": {
      "type": "string"
    }
  }
}
